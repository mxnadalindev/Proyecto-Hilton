<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= plato.nombre %> — Costos</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
</head>
<body>
<div class="app-layout">
  <header class="header">
    <a href="/inicio" class="header-logo"><span class="logo-moneda">Hilton</span></a>
    <nav class="header-nav">
      <a href="/eventos"  class="nav-link"><i class="ti ti-calendar-event"></i> Eventos</a>
      <a href="/personal" class="nav-link"><i class="ti ti-users"></i> Personal</a>
      <a href="/horarios" class="nav-link"><i class="ti ti-clock"></i> Horarios</a>
      <a href="/recetas"  class="nav-link"><i class="ti ti-chef-hat"></i> Recetas</a>
      <a href="/costos"   class="nav-link activo"><i class="ti ti-coin"></i> Costos</a>
    </nav>
    <div class="header-user">
      <span class="user-name"><i class="ti ti-user-circle"></i> <%= usuario?.nombre %></span>
      <a href="/logout" class="btn-logout"><i class="ti ti-logout"></i> Salir</a>
    </div>
  </header>

  <main class="main-content">

    <div class="seccion-header">
      <div class="seccion-header-left">
        <p class="seccion-label"><a href="/costos" style="color:var(--gris-texto);text-decoration:none;display:inline-flex;align-items:center;gap:4px;font-size:0.75rem;"><i class="ti ti-arrow-left"></i> Costos</a></p>
        <h1 class="seccion-titulo"><%= plato.nombre %></h1>
      </div>
      <form method="POST" action="/costos/plato/<%= plato.id %>/eliminar"
            onsubmit="return confirm('¿Eliminar este plato?')">
        <button type="submit" class="btn-danger"><i class="ti ti-trash"></i> Eliminar</button>
      </form>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">

      <!-- Resumen del plato -->
      <div class="form-card">
        <p class="form-card-title"><i class="ti ti-chart-pie"></i> Resumen de costos</p>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px;">
          <div style="background:var(--gris-fondo);border-radius:10px;padding:16px;text-align:center;">
            <p style="font-size:0.65rem;color:var(--gris-texto);text-transform:uppercase;letter-spacing:0.1em;margin:0 0 6px;">Costo total</p>
            <p style="font-size:1.5rem;font-weight:700;color:var(--azul);margin:0;">$<%= parseFloat(plato.costo_total).toFixed(2) %></p>
          </div>
          <div style="background:var(--gris-fondo);border-radius:10px;padding:16px;text-align:center;">
            <p style="font-size:0.65rem;color:var(--gris-texto);text-transform:uppercase;letter-spacing:0.1em;margin:0 0 6px;">Precio venta sugerido</p>
            <p style="font-size:1.5rem;font-weight:700;color:#16a34a;margin:0;">$<%= (parseFloat(plato.costo_total) * (1 + parseFloat(plato.margen_ganancia)/100)).toFixed(2) %></p>
          </div>
          <div style="background:var(--gris-fondo);border-radius:10px;padding:16px;text-align:center;">
            <p style="font-size:0.65rem;color:var(--gris-texto);text-transform:uppercase;letter-spacing:0.1em;margin:0 0 6px;">Margen ganancia</p>
            <p style="font-size:1.5rem;font-weight:700;color:#f59e0b;margin:0;"><%= plato.margen_ganancia %>%</p>
          </div>
          <div style="background:var(--gris-fondo);border-radius:10px;padding:16px;text-align:center;">
            <p style="font-size:0.65rem;color:var(--gris-texto);text-transform:uppercase;letter-spacing:0.1em;margin:0 0 6px;">Porciones</p>
            <p style="font-size:1.5rem;font-weight:700;color:var(--negro);margin:0;"><%= plato.porciones %></p>
          </div>
        </div>

        <% if (plato.porciones > 1 && plato.costo_total > 0) { %>
        <div style="background:var(--azul-claro);border-radius:8px;padding:12px;font-size:0.78rem;color:var(--azul);">
          <i class="ti ti-info-circle"></i>
          Costo por porción: <strong>$<%= (parseFloat(plato.costo_total) / plato.porciones).toFixed(2) %></strong>
          · Precio venta por porción: <strong>$<%= (parseFloat(plato.costo_total) * (1 + parseFloat(plato.margen_ganancia)/100) / plato.porciones).toFixed(2) %></strong>
        </div>
        <% } %>
      </div>

      <!-- Agregar ingrediente -->
      <div class="form-card">
        <p class="form-card-title"><i class="ti ti-plus"></i> Agregar ingrediente</p>
        <form method="POST" action="/costos/plato/<%= plato.id %>/insumo">
          <div class="field" style="margin-bottom:12px;">
            <label>Insumo</label>
            <select name="insumo_id" required style="width:100%;background:var(--gris-fondo);border:1px solid var(--gris-borde);border-radius:8px;padding:10px 12px;font-size:0.85rem;outline:none;">
              <option value="">Seleccionar insumo...</option>
              <% todosInsumos.forEach(ins => { %>
                <option value="<%= ins.id %>"><%= ins.nombre %> ($<%= parseFloat(ins.precio_unitario).toFixed(2) %>/<%= ins.unidad %>)</option>
              <% }) %>
            </select>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px;">
            <div class="field">
              <label>Cantidad</label>
              <input type="number" name="cantidad" placeholder="0" step="0.01" min="0" required>
            </div>
            <div class="field">
              <label>Unidad</label>
              <select name="unidad" style="width:100%;background:var(--gris-fondo);border:1px solid var(--gris-borde);border-radius:8px;padding:10px 12px;font-size:0.85rem;outline:none;">
                <option value="kg">kg</option>
                <option value="g">g</option>
                <option value="lt">lt</option>
                <option value="ml">ml</option>
                <option value="unidad">unidad</option>
              </select>
            </div>
          </div>
          <button type="submit" class="btn-primary" style="width:100%;">
            <i class="ti ti-plus"></i> Agregar ingrediente
          </button>
        </form>
      </div>

      <!-- Lista de ingredientes -->
      <div class="form-card" style="grid-column:1/-1;">
        <p class="form-card-title"><i class="ti ti-list"></i> Ingredientes del plato</p>
        <% if (ingredientes.length > 0) { %>
        <table class="tabla">
          <thead>
            <tr>
              <th>Ingrediente</th>
              <th>Cantidad</th>
              <th>Precio unitario</th>
              <th>Costo parcial</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% ingredientes.forEach(ing => { %>
            <tr>
              <td style="font-weight:500;"><%= ing.insumo_nombre %></td>
              <td><%= ing.cantidad %> <%= ing.unidad %></td>
              <td style="color:var(--gris-texto);">$<%= parseFloat(ing.precio_unitario).toFixed(2) %></td>
              <td style="font-weight:600;color:var(--azul);">$<%= parseFloat(ing.costo_parcial).toFixed(2) %></td>
              <td>
                <form method="POST" action="/costos/plato/<%= plato.id %>/insumo/<%= ing.id %>/eliminar" style="margin:0;">
                  <button type="submit" style="background:none;border:none;color:var(--gris-borde);cursor:pointer;font-size:15px;" title="Quitar">
                    <i class="ti ti-x"></i>
                  </button>
                </form>
              </td>
            </tr>
            <% }) %>
            <tr style="background:var(--gris-fondo);">
              <td colspan="3" style="font-weight:600;text-align:right;padding-right:12px;">TOTAL</td>
              <td style="font-weight:700;color:var(--azul);font-size:1rem;">$<%= parseFloat(plato.costo_total).toFixed(2) %></td>
              <td></td>
            </tr>
          </tbody>
        </table>
        <% } else { %>
          <p style="font-size:0.82rem;color:var(--gris-texto);font-style:italic;padding:16px 0;">Sin ingredientes todavía. Agregá el primero.</p>
        <% } %>
      </div>

    </div>

  </main>
</div>

<style>
.form-card { background:var(--blanco);border:1px solid var(--gris-borde);border-radius:12px;padding:24px;box-shadow:var(--sombra); }
.form-card-title { font-size:0.68rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--azul);margin-bottom:18px;display:flex;align-items:center;gap:7px; }
.field { margin-bottom:0; }
.field label { display:block;font-size:0.68rem;font-weight:500;color:var(--negro);margin-bottom:6px; }
.field input { width:100%;background:var(--gris-fondo);border:1px solid var(--gris-borde);border-radius:8px;padding:10px 12px;font-family:var(--font-sans);font-size:0.85rem;color:var(--negro);outline:none; }
.field input:focus { border-color:var(--azul);background:var(--blanco); }
.btn-danger { background:#fef2f2;border:1px solid #fecaca;color:#dc2626;font-family:var(--font-sans);font-size:0.68rem;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;padding:8px 16px;border-radius:8px;cursor:pointer;display:flex;align-items:center;gap:6px;transition:all 0.2s; }
.btn-danger:hover { background:#dc2626;color:#fff; }
</style>

</body>
</html>
