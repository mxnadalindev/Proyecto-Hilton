<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Personal — Hilton</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
</head>
<body>
<div class="app-layout">
  <header class="header">
    <a href="/inicio" class="header-logo"><span class="logo-moneda">Hilton</span></a>
    <nav class="header-nav">
      <a href="/eventos" class="nav-link"><i class="ti ti-calendar-event"></i> Eventos</a>
      <a href="/personal" class="nav-link activo"><i class="ti ti-users"></i> Personal</a>
      <a href="/recetas" class="nav-link"><i class="ti ti-chef-hat"></i> Recetas</a>
    </nav>
    <div class="header-user">
      <span class="user-name"><i class="ti ti-user-circle"></i> <%= usuario?.nombre %></span>
      <a href="/logout" class="btn-logout"><i class="ti ti-logout"></i> Salir</a>
    </div>
  </header>
  <main class="main-content">
    <div class="seccion-header">
      <div class="seccion-header-left">
        <p class="seccion-label">Portal interno</p>
        <h1 class="seccion-titulo">Personal</h1>
      </div>
    </div>
    <div class="tabla-wrap">
      <table class="tabla">
        <thead><tr><th>Nombre</th><th>Correo</th><th>Rol</th><th>Alta</th></tr></thead>
        <tbody>
          <% if (personal.length > 0) { %>
            <% personal.forEach(p => { %>
            <tr>
              <td><%= p.nombre %></td>
              <td><%= p.email %></td>
              <td><span class="rol-badge <%= p.rol === 'admin' ? 'rol-admin' : 'rol-empleado' %>"><%= p.rol %></span></td>
              <td><%= p.creado_en ? p.creado_en.substring(0,10) : '—' %></td>
            </tr>
            <% }) %>
          <% } else { %>
            <tr><td colspan="4" style="text-align:center;padding:48px;color:var(--gris-texto);font-style:italic;">No hay personal registrado todavía.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </main>
</div>
</body>
</html>
