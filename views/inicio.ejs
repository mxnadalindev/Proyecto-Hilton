<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="theme-color" content="#2563eb">
  <link rel="manifest" href="/manifest.json">
  <title>Inicio — Hilton</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
</head>
<body>
<div class="app-layout">

  <header class="header">
    <a href="/inicio" class="header-logo"><span class="logo-moneda">Hilton</span></a>
    <nav class="header-nav desktop-only">
      <a href="/eventos"  class="nav-link"><i class="ti ti-calendar-event"></i> Eventos</a>
      <a href="/personal" class="nav-link"><i class="ti ti-users"></i> Personal</a>
      <a href="/horarios" class="nav-link"><i class="ti ti-clock"></i> Horarios</a>
      <a href="/recetas"  class="nav-link"><i class="ti ti-chef-hat"></i> Recetas</a>
      <a href="/costos"   class="nav-link"><i class="ti ti-coin"></i> Costos</a>
    </nav>
    <div class="header-user">
      <span class="user-name desktop-only"><i class="ti ti-user-circle"></i> <%= usuario?.nombre %></span>
      <a href="/logout" class="btn-logout">
        <i class="ti ti-logout"></i>
        <span class="logout-text">Cerrar sesión</span>
      </a>
    </div>
  </header>

  <main class="main-content">
    <div class="inicio-hero">
      <p class="inicio-saludo">Portal interno · Hilton Buenos Aires</p>
      <h1 class="inicio-titulo">Bienvenido,<br><span><%= usuario?.nombre %></span></h1>

      <div class="inicio-grid" style="grid-template-columns:repeat(5,1fr);max-width:1100px;">

        <a href="/eventos" class="inicio-card fade-up">
          <div class="card-icon"><i class="ti ti-calendar-event"></i></div>
          <span class="card-num">01</span>
          <span class="card-nombre">Eventos</span>
          <span class="card-desc">Gestión y presupuestos</span>
        </a>

        <a href="/personal" class="inicio-card fade-up">
          <div class="card-icon"><i class="ti ti-users"></i></div>
          <span class="card-num">02</span>
          <span class="card-nombre">Personal</span>
          <span class="card-desc">Equipo interno</span>
        </a>

        <a href="/horarios" class="inicio-card fade-up">
          <div class="card-icon"><i class="ti ti-clock"></i></div>
          <span class="card-num">03</span>
          <span class="card-nombre">Horarios</span>
          <span class="card-desc">Turnos automáticos</span>
        </a>

        <a href="/recetas" class="inicio-card fade-up">
          <div class="card-icon"><i class="ti ti-chef-hat"></i></div>
          <span class="card-num">04</span>
          <span class="card-nombre">Recetas</span>
          <span class="card-desc">Recetario y videos</span>
        </a>

        <a href="/costos" class="inicio-card fade-up">
          <div class="card-icon"><i class="ti ti-coin"></i></div>
          <span class="card-num">05</span>
          <span class="card-nombre">Costos</span>
          <span class="card-desc">Insumos y precios</span>
        </a>

      </div>
    </div>
  </main>

  <nav class="mobile-nav">
    <a href="/eventos"  class="mobile-nav-link"><i class="ti ti-calendar-event"></i>Eventos</a>
    <a href="/personal" class="mobile-nav-link"><i class="ti ti-users"></i>Personal</a>
    <a href="/horarios" class="mobile-nav-link"><i class="ti ti-clock"></i>Horarios</a>
    <a href="/recetas"  class="mobile-nav-link"><i class="ti ti-chef-hat"></i>Recetas</a>
    <a href="/costos"   class="mobile-nav-link"><i class="ti ti-coin"></i>Costos</a>
  </nav>

</div>
</body>
</html>
