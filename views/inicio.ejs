<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="theme-color" content="#2563eb">
  <link rel="manifest" href="/manifest.json">
  <title>Inicio — Hilton</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
</head>
<body>
<div class="app-layout">

  <header class="header">
    <a href="/inicio" class="header-logo"><span class="logo-moneda">Hilton</span></a>
    <nav class="header-nav desktop-only">
      <% const _d = usuario?.departamento; %>
      <% if (_d === 'cocina' || _d === 'ayb') { %>
        <a href="/eventos"  class="nav-link"><i class="ti ti-calendar-event"></i> Eventos</a>
        <a href="/personal" class="nav-link"><i class="ti ti-users"></i> Personal</a>
        <a href="/horarios" class="nav-link"><i class="ti ti-clock"></i> Horarios</a>
        <a href="/recetas"  class="nav-link"><i class="ti ti-chef-hat"></i> Recetas</a>
        <a href="/costos"   class="nav-link"><i class="ti ti-coin"></i> Costos</a>
      <% } %>
      <% if (_d === 'compras') { %>
        <a href="/compras"  class="nav-link"><i class="ti ti-shopping-cart"></i> Compras</a>
      <% } %>
      <% if (_d === 'finanzas') { %>
        <a href="/finanzas" class="nav-link"><i class="ti ti-report-money"></i> Finanzas</a>
      <% } %>
    </nav>
    <div class="header-user">
      <span class="user-name desktop-only"><i class="ti ti-user-circle"></i> <%= usuario?.nombre %></span>
      <a href="/logout" class="btn-logout">
        <i class="ti ti-logout"></i>
        <span class="logout-text">Cerrar sesión</span>
      </a>
    </div>
  </header>

  <main class="main-content">
    <div class="inicio-hero">
      <p class="inicio-saludo">Portal interno · Hilton Buenos Aires</p>
      <h1 class="inicio-titulo">Bienvenido,<br><span><%= usuario?.nombre %></span></h1>

      <%
        const depto = usuario?.departamento;
        let modulos = [];
        if (depto === 'cocina' || depto === 'ayb') {
          modulos = [
            { href: '/eventos',  icon: 'ti-calendar-event', nombre: 'Eventos',  desc: 'Gestión y presupuestos' },
            { href: '/personal', icon: 'ti-users',          nombre: 'Personal', desc: 'Equipo interno' },
            { href: '/horarios', icon: 'ti-clock',          nombre: 'Horarios', desc: 'Turnos automáticos' },
            { href: '/recetas',  icon: 'ti-chef-hat',       nombre: 'Recetas',  desc: 'Recetario y videos' },
            { href: '/costos',   icon: 'ti-coin',           nombre: 'Costos',   desc: 'Insumos y precios' },
          ];
        } else if (depto === 'compras') {
          modulos = [
            { href: '/compras', icon: 'ti-shopping-cart', nombre: 'Compras', desc: 'Órdenes y proveedores' },
          ];
        } else if (depto === 'finanzas') {
          modulos = [
            { href: '/finanzas', icon: 'ti-report-money', nombre: 'Finanzas', desc: 'Reportes y presupuestos' },
          ];
        }
      %>

      <div class="inicio-grid inicio-grid-<%= modulos.length %>">
        <% modulos.forEach((m, i) => { %>
          <a href="<%= m.href %>" class="inicio-card fade-up">
            <div class="card-icon"><i class="ti <%= m.icon %>"></i></div>
            <span class="card-num"><%= String(i + 1).padStart(2, '0') %></span>
            <span class="card-nombre"><%= m.nombre %></span>
            <span class="card-desc"><%= m.desc %></span>
          </a>
        <% }) %>
      </div>

    </div>
  </main>

  <nav class="mobile-nav">
    <% if (depto === 'cocina' || depto === 'ayb') { %>
      <a href="/eventos"  class="mobile-nav-link"><i class="ti ti-calendar-event"></i><span>Eventos</span></a>
      <a href="/personal" class="mobile-nav-link"><i class="ti ti-users"></i><span>Personal</span></a>
      <a href="/horarios" class="mobile-nav-link"><i class="ti ti-clock"></i><span>Horarios</span></a>
      <a href="/recetas"  class="mobile-nav-link"><i class="ti ti-chef-hat"></i><span>Recetas</span></a>
      <a href="/costos"   class="mobile-nav-link"><i class="ti ti-coin"></i><span>Costos</span></a>
    <% } %>
    <% if (depto === 'compras') { %>
      <a href="/compras"  class="mobile-nav-link"><i class="ti ti-shopping-cart"></i><span>Compras</span></a>
    <% } %>
    <% if (depto === 'finanzas') { %>
      <a href="/finanzas" class="mobile-nav-link"><i class="ti ti-report-money"></i><span>Finanzas</span></a>
    <% } %>
  </nav>

</div>
</body>
</html>
