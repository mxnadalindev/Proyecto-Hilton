<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%- title || 'Portal Interno' %> — Hilton Buenos Aires</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
</head>
<body>

<div class="app-layout">

  <header class="header">
    <a href="/inicio" class="header-logo">
      <span class="logo-moneda">Hilton</span>
    </a>

    <nav class="header-nav">
      <a href="/eventos"  class="nav-link <%= path === 'eventos'  ? 'activo' : '' %>"><i class="ti ti-calendar-event"></i> Eventos</a>
      <a href="/personal" class="nav-link <%= path === 'personal' ? 'activo' : '' %>"><i class="ti ti-users"></i> Personal</a>
      <a href="/recetas"  class="nav-link <%= path === 'recetas'  ? 'activo' : '' %>"><i class="ti ti-chef-hat"></i> Recetas</a>
      <a href="/horarios" class="nav-link <%= path === 'horarios' ? 'activo' : '' %>"><i class="ti ti-clock"></i> Horarios</a>
      <a href="/costos"   class="nav-link <%= path === 'costos'   ? 'activo' : '' %>"><i class="ti ti-currency-dollar"></i> Costos</a>
    </nav>

    <div class="header-user">
      <span class="user-name"><i class="ti ti-user-circle"></i> <%= usuario?.nombre %></span>
      <a href="/logout" class="btn-logout">
        <i class="ti ti-logout"></i>
        <span class="logout-text">Salir</span>
      </a>
    </div>
  </header>

  <main class="main-content">
    <%- body %>
  </main>

  <%# ── Menú inferior solo en mobile ── %>
  <nav class="mobile-nav">
    <a href="/inicio"   class="mobile-nav-link <%= path === 'inicio'   ? 'activo' : '' %>">
      <i class="ti ti-home"></i>
      <span>Inicio</span>
    </a>
    <a href="/eventos"  class="mobile-nav-link <%= path === 'eventos'  ? 'activo' : '' %>">
      <i class="ti ti-calendar-event"></i>
      <span>Eventos</span>
    </a>
    <a href="/personal" class="mobile-nav-link <%= path === 'personal' ? 'activo' : '' %>">
      <i class="ti ti-users"></i>
      <span>Personal</span>
    </a>
    <a href="/recetas"  class="mobile-nav-link <%= path === 'recetas'  ? 'activo' : '' %>">
      <i class="ti ti-chef-hat"></i>
      <span>Recetas</span>
    </a>
    <a href="/horarios" class="mobile-nav-link <%= path === 'horarios' ? 'activo' : '' %>">
      <i class="ti ti-clock"></i>
      <span>Horarios</span>
    </a>
    <a href="/costos"   class="mobile-nav-link <%= path === 'costos'   ? 'activo' : '' %>">
      <i class="ti ti-currency-dollar"></i>
      <span>Costos</span>
    </a>
  </nav>

</div>

</body>
</html>
