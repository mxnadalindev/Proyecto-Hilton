<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%- title || 'Portal Interno' %> — Hilton Buenos Aires</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
</head>
<body>

<div class="app-layout">

  <header class="header">
    <a href="/inicio" class="header-logo">
      <span class="logo-moneda">Hilton</span>
    </a>

    <nav class="header-nav">
      <a href="/eventos"  class="nav-link <%= path === 'eventos'  ? 'activo' : '' %>"><i class="ti ti-calendar-event"></i> Eventos</a>
      <a href="/personal" class="nav-link <%= path === 'personal' ? 'activo' : '' %>"><i class="ti ti-users"></i> Personal</a>
      <a href="/recetas"  class="nav-link <%= path === 'recetas'  ? 'activo' : '' %>"><i class="ti ti-chef-hat"></i> Recetas</a>
    </nav>

    <div class="header-user">
      <span class="user-name"><i class="ti ti-user-circle"></i> <%= usuario?.nombre %></span>
      <a href="/logout" class="btn-logout"><i class="ti ti-logout"></i> Salir</a>
    </div>
  </header>

  <main class="main-content">
    <%- body %>
  </main>

</div>

</body>
</html>
