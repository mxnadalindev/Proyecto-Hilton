<header class="header">
  <a href="/inicio" class="header-logo"><span class="logo-moneda">Hilton</span></a>
  <nav class="header-nav desktop-only">
    <% const _d = usuario?.departamento; const _r = usuario?.rol; %>
    <% if (_d === 'cocina' || _d === 'ayb' || _r === 'admin') { %>
      <a href="/eventos"  class="nav-link <%= (typeof path !== 'undefined' && path === 'eventos')  ? 'activo' : '' %>"><i class="ti ti-calendar-event"></i> Eventos</a>
      <a href="/personal" class="nav-link <%= (typeof path !== 'undefined' && path === 'personal') ? 'activo' : '' %>"><i class="ti ti-users"></i> Personal</a>
      <a href="/horarios" class="nav-link <%= (typeof path !== 'undefined' && path === 'horarios') ? 'activo' : '' %>"><i class="ti ti-clock"></i> Horarios</a>
      <a href="/recetas"  class="nav-link <%= (typeof path !== 'undefined' && path === 'recetas')  ? 'activo' : '' %>"><i class="ti ti-chef-hat"></i> Recetas</a>
      <a href="/costos"   class="nav-link <%= (typeof path !== 'undefined' && path === 'costos')   ? 'activo' : '' %>"><i class="ti ti-coin"></i> Costos</a>
    <% } %>
    <% if (_d === 'compras' || _r === 'admin') { %>
      <a href="/compras"  class="nav-link <%= (typeof path !== 'undefined' && path === 'compras')  ? 'activo' : '' %>"><i class="ti ti-shopping-cart"></i> Compras</a>
    <% } %>
    <% if (_d === 'finanzas' || _r === 'admin') { %>
      <a href="/finanzas" class="nav-link <%= (typeof path !== 'undefined' && path === 'finanzas') ? 'activo' : '' %>"><i class="ti ti-report-money"></i> Finanzas</a>
    <% } %>
  </nav>
  <div class="header-user">
    <span class="user-name desktop-only"><i class="ti ti-user-circle"></i> <%= usuario?.nombre %></span>
    <a href="/logout" class="btn-logout"><i class="ti ti-logout"></i><span class="logout-text"> Cerrar sesión</span></a>
  </div>
</header>
