<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="theme-color" content="#0f172a">
  <title>Acceso — Hilton Buenos Aires</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:wght@400;500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --navy: #0f172a; --navy-800: #1e293b; --navy-700: #334155; --navy-600: #475569;
      --slate-400: #94a3b8; --slate-200: #e2e8f0; --slate-100: #f1f5f9; --white: #ffffff;
      --accent: #3b82f6; --accent-h: #2563eb; --accent-l: #dbeafe;
      --gold: #c9a84c; --error: #ef4444; --error-l: #fef2f2; --success: #22c55e; --tr: 0.2s ease;
    }
    html, body { height: 100%; }
    body { font-family: 'Inter', system-ui, sans-serif; font-size: 15px; background: var(--navy); color: var(--white); min-height: 100vh; display: grid; grid-template-columns: 1fr 1fr; }

    /* Panel izquierdo */
    .panel-left { display: flex; flex-direction: column; justify-content: space-between; padding: 48px; position: relative; overflow: hidden; background: var(--navy); }
    .panel-left::before { content: ''; position: absolute; top: -200px; left: -200px; width: 600px; height: 600px; background: radial-gradient(circle, rgba(59,130,246,0.12) 0%, transparent 70%); pointer-events: none; }
    .panel-left::after { content: ''; position: absolute; bottom: -150px; right: -100px; width: 400px; height: 400px; background: radial-gradient(circle, rgba(201,168,76,0.08) 0%, transparent 70%); pointer-events: none; }
    .brand { position: relative; z-index: 1; }
    .brand-logo { display: inline-flex; align-items: center; gap: 12px; margin-bottom: 48px; }
    .brand-icon { width: 42px; height: 42px; background: var(--accent); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 20px; color: var(--white); }
    .brand-name { font-family: 'Playfair Display', serif; font-size: 1.4rem; font-weight: 500; letter-spacing: 0.04em; color: var(--white); }
    .brand-sub { font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--slate-400); }
    .hero-content { position: relative; z-index: 1; }
    .hero-eyebrow { font-size: 0.68rem; font-weight: 500; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
    .hero-eyebrow::before { content: ''; display: block; width: 24px; height: 1px; background: var(--accent); }
    .hero-title { font-family: 'Playfair Display', serif; font-size: clamp(2rem, 3.5vw, 3rem); font-weight: 400; line-height: 1.2; color: var(--white); margin-bottom: 20px; }
    .hero-title span { color: var(--gold); }
    .hero-desc { font-size: 0.9rem; line-height: 1.7; color: var(--slate-400); max-width: 360px; margin-bottom: 48px; }
    .features { display: flex; flex-direction: column; gap: 16px; }
    .feature { display: flex; align-items: flex-start; gap: 12px; }
    .feature-icon { width: 32px; height: 32px; flex-shrink: 0; background: rgba(59,130,246,0.1); border: 1px solid rgba(59,130,246,0.2); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 15px; color: var(--accent); }
    .feature-text strong { display: block; font-size: 0.83rem; font-weight: 500; color: var(--white); margin-bottom: 2px; }
    .feature-text span { font-size: 0.75rem; color: var(--slate-400); }
    .panel-left-footer { position: relative; z-index: 1; font-size: 0.72rem; color: var(--navy-600); }

    /* Panel derecho */
    .panel-right { background: var(--white); display: flex; align-items: center; justify-content: center; padding: 48px; position: relative; }
    .form-box { width: 100%; max-width: 400px; }
    .form-header { margin-bottom: 28px; }
    .form-title { font-family: 'Playfair Display', serif; font-size: 1.8rem; font-weight: 400; color: var(--navy); margin-bottom: 8px; }
    .form-subtitle { font-size: 0.85rem; color: var(--navy-600); }

    /* Tabs login/registro */
    .form-tabs { display: flex; gap: 0; margin-bottom: 28px; border-bottom: 2px solid var(--slate-200); }
    .form-tab { flex: 1; padding: 10px; background: none; border: none; font-family: 'Inter', sans-serif; font-size: 0.82rem; font-weight: 500; color: var(--slate-400); cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -2px; transition: all var(--tr); }
    .form-tab.activo { color: var(--accent); border-bottom-color: var(--accent); }

    /* Banners */
    .error-banner { display: flex; align-items: center; gap: 10px; background: var(--error-l); border: 1px solid #fecaca; border-radius: 10px; padding: 12px 14px; margin-bottom: 20px; font-size: 0.82rem; color: #dc2626; animation: slideDown 0.2s ease; }
    .success-banner { display: flex; align-items: center; gap: 10px; background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 10px; padding: 12px 14px; margin-bottom: 20px; font-size: 0.82rem; color: #16a34a; animation: slideDown 0.2s ease; }
    .info-banner { display: flex; align-items: center; gap: 10px; background: var(--accent-l); border: 1px solid #bfdbfe; border-radius: 10px; padding: 12px 14px; margin-bottom: 20px; font-size: 0.82rem; color: var(--accent-h); animation: slideDown 0.2s ease; }
    @keyframes slideDown { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: translateY(0); } }

    /* Campos */
    .field { margin-bottom: 16px; }
    .field-label { display: flex; justify-content: space-between; align-items: center; margin-bottom: 7px; }
    .field-label span { font-size: 0.75rem; font-weight: 500; color: var(--navy); letter-spacing: 0.03em; }
    .field-label a { font-size: 0.72rem; color: var(--accent); text-decoration: none; }
    .field-label a:hover { text-decoration: underline; }
    .input-wrap { position: relative; display: flex; align-items: center; }
    .input-icon { position: absolute; left: 14px; font-size: 17px; color: var(--slate-400); pointer-events: none; transition: color var(--tr); }
    .input-wrap input { width: 100%; height: 46px; background: var(--slate-100); border: 1.5px solid var(--slate-200); border-radius: 10px; padding: 0 44px; font-family: 'Inter', sans-serif; font-size: 0.88rem; color: var(--navy); outline: none; transition: border-color var(--tr), background var(--tr), box-shadow var(--tr); }
    .input-wrap input::placeholder { color: var(--slate-400); }
    .input-wrap input:focus { background: var(--white); border-color: var(--accent); box-shadow: 0 0 0 3px rgba(59,130,246,0.12); }
    .toggle-pass { position: absolute; right: 14px; background: none; border: none; font-size: 17px; color: var(--slate-400); cursor: pointer; padding: 4px; transition: color var(--tr); }
    .toggle-pass:hover { color: var(--navy); }
    .field-valid .input-wrap input { border-color: var(--success); }
    .field-error .input-wrap input { border-color: var(--error); background: var(--error-l); }

    .check-row { display: flex; align-items: center; gap: 8px; margin-bottom: 22px; }
    .check-row input[type="checkbox"] { width: 16px; height: 16px; accent-color: var(--accent); cursor: pointer; }
    .check-row label { font-size: 0.8rem; color: var(--navy-600); cursor: pointer; user-select: none; }

    .btn-submit { width: 100%; height: 48px; background: var(--accent); border: none; border-radius: 10px; color: var(--white); font-family: 'Inter', sans-serif; font-size: 0.82rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; transition: background var(--tr), transform var(--tr), box-shadow var(--tr); position: relative; overflow: hidden; }
    .btn-submit:hover { background: var(--accent-h); transform: translateY(-1px); box-shadow: 0 8px 20px rgba(59,130,246,0.3); }
    .btn-submit:active { transform: translateY(0); box-shadow: none; }
    .btn-submit:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }
    .btn-submit .spinner { display: none; width: 18px; height: 18px; border: 2px solid rgba(255,255,255,0.3); border-top-color: var(--white); border-radius: 50%; animation: spin 0.7s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .btn-submit.loading .spinner { display: block; }
    .btn-submit.loading .btn-text { opacity: 0; position: absolute; }

    .divider { display: flex; align-items: center; gap: 12px; margin: 20px 0; }
    .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: var(--slate-200); }
    .divider span { font-size: 0.72rem; color: var(--slate-400); }
    .system-badge { display: flex; align-items: center; justify-content: center; gap: 8px; padding: 10px; background: var(--slate-100); border-radius: 10px; font-size: 0.72rem; color: var(--navy-600); }
    .system-badge i { font-size: 15px; color: var(--accent); }

    /* Hint contraseña */
    .pass-hint { font-size: 0.7rem; color: var(--slate-400); margin-top: 5px; }

    @media (max-width: 768px) {
      body { grid-template-columns: 1fr; }
      .panel-left { display: none; }
      .panel-right { padding: 32px 24px; min-height: 100vh; background: var(--navy); }
      .form-box { max-width: 100%; }
      .form-title { color: var(--white); }
      .form-subtitle { color: var(--slate-400); }
      .form-tabs { border-bottom-color: var(--navy-700); }
      .form-tab { color: var(--navy-600); }
      .form-tab.activo { color: var(--accent); }
      .field-label span { color: var(--slate-200); }
      .check-row label { color: var(--slate-400); }
      .input-wrap input { background: var(--navy-800); border-color: var(--navy-700); color: var(--white); }
      .input-wrap input::placeholder { color: var(--navy-600); }
      .input-wrap input:focus { background: var(--navy-700); }
      .system-badge { background: var(--navy-800); }
      .divider::before, .divider::after { background: var(--navy-700); }
    }
    @media (max-width: 480px) { .panel-right { padding: 24px 20px; } }
  </style>
</head>
<body>

<!-- Panel izquierdo -->
<div class="panel-left">
  <div class="brand">
    <div class="brand-logo">
      <div class="brand-icon"><i class="ti ti-building" aria-hidden="true"></i></div>
      <div>
        <div class="brand-name">Hilton</div>
        <div class="brand-sub">Buenos Aires</div>
      </div>
    </div>
    <div class="hero-content">
      <p class="hero-eyebrow">Portal interno</p>
      <h1 class="hero-title">Gestión<br>gastronómica<br><span>inteligente</span></h1>
      <p class="hero-desc">Plataforma centralizada para la gestión operativa del equipo de cocina. Horarios, recetas, eventos y costos en un solo lugar.</p>
      <div class="features">
        <div class="feature">
          <div class="feature-icon"><i class="ti ti-clock"></i></div>
          <div class="feature-text"><strong>Horarios automáticos</strong><span>Generación inteligente por turnos y jerarquía</span></div>
        </div>
        <div class="feature">
          <div class="feature-icon"><i class="ti ti-chef-hat"></i></div>
          <div class="feature-text"><strong>Biblioteca de recetas</strong><span>Recetario digital con videos e imágenes</span></div>
        </div>
        <div class="feature">
          <div class="feature-icon"><i class="ti ti-coin"></i></div>
          <div class="feature-text"><strong>Control de costos</strong><span>Costeo automático de platos e insumos</span></div>
        </div>
      </div>
    </div>
  </div>
  <div class="panel-left-footer">© 2026 Hilton Buenos Aires · Future Lab</div>
</div>

<!-- Panel derecho -->
<div class="panel-right">
  <div class="form-box">

    <div class="form-header">
      <h2 class="form-title" id="formTitle">Bienvenido</h2>
      <p class="form-subtitle" id="formSubtitle">Ingresá con tu cuenta corporativa para continuar</p>
    </div>

    <!-- Tabs -->
    <div class="form-tabs">
      <button class="form-tab activo" onclick="mostrarTab('login')" id="tab-login">Iniciar sesión</button>
      <button class="form-tab" onclick="mostrarTab('registro')" id="tab-registro">Registrarse</button>
    </div>

    <!-- Mensajes -->
    <% if (error) { %>
    <div class="error-banner"><i class="ti ti-alert-circle"></i> <%= error %></div>
    <% } %>
    <% if (typeof info !== 'undefined' && info) { %>
    <div class="info-banner"><i class="ti ti-info-circle"></i> <%= info %></div>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
    <div class="success-banner"><i class="ti ti-check"></i> <%= success %></div>
    <% } %>
    <% if (typeof errorReg !== 'undefined' && errorReg) { %>
    <div class="error-banner"><i class="ti ti-alert-circle"></i> <%= errorReg %></div>
    <% } %>

    <!-- Formulario LOGIN -->
    <div id="form-login">
      <form method="POST" action="/login" id="loginForm" novalidate>
        <div class="field" id="field-email">
          <div class="field-label"><span>Correo electrónico</span></div>
          <div class="input-wrap">
            <i class="ti ti-mail input-icon"></i>
            <input type="email" name="email" id="email" placeholder="tu.nombre@hilton.com" autocomplete="email" required>
          </div>
        </div>
        <div class="field">
          <div class="field-label">
            <span>Contraseña</span>
            <span style="font-size:0.7rem;color:var(--slate-400);">Contactá al administrador</span>
          </div>
          <div class="input-wrap">
            <i class="ti ti-lock input-icon"></i>
            <input type="password" name="password" id="password" placeholder="••••••••" autocomplete="current-password" required>
            <button type="button" class="toggle-pass" onclick="togglePass('password','eye1')">
              <i class="ti ti-eye" id="eye1"></i>
            </button>
          </div>
        </div>
        <div class="check-row">
          <input type="checkbox" id="remember" name="remember">
          <label for="remember">Mantener sesión iniciada</label>
        </div>
        <button type="submit" class="btn-submit" id="submitBtn">
          <div class="spinner"></div>
          <span class="btn-text">Ingresar al portal</span>
          <i class="ti ti-arrow-right btn-text"></i>
        </button>
      </form>
    </div>

    <!-- Formulario REGISTRO -->
    <div id="form-registro" style="display:none;">
      <form method="POST" action="/registro" novalidate>
        <div class="field">
          <div class="field-label"><span>Nombre y apellido</span></div>
          <div class="input-wrap">
            <i class="ti ti-user input-icon"></i>
            <input type="text" name="nombre" placeholder="Juan García" required>
          </div>
        </div>
        <div class="field">
          <div class="field-label"><span>Correo electrónico corporativo</span></div>
          <div class="input-wrap">
            <i class="ti ti-mail input-icon"></i>
            <input type="email" name="email" placeholder="tu.nombre@hilton.com" required>
          </div>
        </div>
        <div class="field">
          <div class="field-label"><span>Contraseña</span></div>
          <div class="input-wrap">
            <i class="ti ti-lock input-icon"></i>
            <input type="password" name="password" id="pass-reg" placeholder="••••••••" required>
            <button type="button" class="toggle-pass" onclick="togglePass('pass-reg','eye2')">
              <i class="ti ti-eye" id="eye2"></i>
            </button>
          </div>
          <p class="pass-hint">Mínimo 8 caracteres, una mayúscula y un número.</p>
        </div>
        <div class="field">
          <div class="field-label"><span>Repetir contraseña</span></div>
          <div class="input-wrap">
            <i class="ti ti-lock input-icon"></i>
            <input type="password" name="password2" placeholder="••••••••" required>
          </div>
        </div>
        <button type="submit" class="btn-submit" style="margin-top:4px;">
          <span class="btn-text">Crear cuenta</span>
          <i class="ti ti-user-plus btn-text"></i>
        </button>
      </form>
    </div>

    <div class="divider"><span>Sistema seguro</span></div>
    <div class="system-badge">
      <i class="ti ti-shield-check"></i>
      Acceso restringido al personal autorizado · Red interna Hilton
    </div>

  </div>
</div>

<script>
// Mostrar tab correcto según mensajes del servidor
<% if (typeof errorReg !== 'undefined' && errorReg) { %>
window.addEventListener('DOMContentLoaded', () => mostrarTab('registro'));
<% } %>
<% if (typeof success !== 'undefined' && success) { %>
window.addEventListener('DOMContentLoaded', () => mostrarTab('login'));
<% } %>

function mostrarTab(tab) {
  const isLogin = tab === 'login';
  document.getElementById('form-login').style.display    = isLogin ? 'block' : 'none';
  document.getElementById('form-registro').style.display = isLogin ? 'none'  : 'block';
  document.getElementById('tab-login').className    = 'form-tab' + (isLogin ? ' activo' : '');
  document.getElementById('tab-registro').className = 'form-tab' + (!isLogin ? ' activo' : '');
  document.getElementById('formTitle').textContent    = isLogin ? 'Bienvenido' : 'Crear cuenta';
  document.getElementById('formSubtitle').textContent = isLogin
    ? 'Ingresá con tu cuenta corporativa para continuar'
    : 'Registrate para acceder al portal';
}

function togglePass(inputId, iconId) {
  const input = document.getElementById(inputId);
  const icon  = document.getElementById(iconId);
  const visible = input.type === 'text';
  input.type = visible ? 'password' : 'text';
  icon.className = visible ? 'ti ti-eye' : 'ti ti-eye-off';
}

const emailInput = document.getElementById('email');
if (emailInput) {
  emailInput.addEventListener('blur', () => {
    const field = document.getElementById('field-email');
    if (emailInput.value && emailInput.checkValidity()) {
      field.className = 'field field-valid';
    } else if (emailInput.value) {
      field.className = 'field field-error';
    }
  });
}

document.getElementById('loginForm').addEventListener('submit', () => {
  const btn = document.getElementById('submitBtn');
  btn.classList.add('loading');
  btn.disabled = true;
});
</script>
</body>
</html>
