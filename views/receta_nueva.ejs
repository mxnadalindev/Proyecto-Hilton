<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nueva Receta — Hilton</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
</head>
<body>
<div class="app-layout">

  <%- include('partials/nav', { path: path }) %>

  <main class="main-content">

    <div class="seccion-header">
      <div class="seccion-header-left">
        <p class="seccion-label"><a href="/recetas" class="back-link"><i class="ti ti-arrow-left"></i> Recetas</a></p>
        <h1 class="seccion-titulo">Nueva receta</h1>
      </div>
    </div>

    <form method="POST" action="/recetas/nueva" enctype="multipart/form-data">
      <div class="form-grid">

        <!-- Columna izquierda -->
        <div class="form-col">
          <div class="form-card">
            <p class="form-card-title"><i class="ti ti-info-circle"></i> Información general</p>
            <div class="field">
              <label>Nombre de la receta</label>
              <input type="text" name="nombre" placeholder="Ej: Risotto de hongos" required>
            </div>
            <div class="field">
              <label>Categoría</label>
              <input type="text" name="categoria" placeholder="Ej: Entrada, Principal, Postre">
            </div>
            <div class="field">
              <label>Área</label>
              <input type="text" name="area" placeholder="Ej: Cocina caliente">
            </div>
            <div class="field">
              <label>Imagen del plato</label>
              <input type="file" name="imagen" accept="image/*" style="padding:8px 0;">
            </div>
          </div>

          <div class="form-card">
            <p class="form-card-title"><i class="ti ti-video"></i> Video de preparación</p>
            <div class="field">
              <label>Subir video desde la PC</label>
              <input type="file" name="video" accept="video/*" style="padding:8px 0;">
            </div>
            <div class="field">
              <label>O pegá un link de YouTube / Google Drive</label>
              <input type="text" name="video_url" placeholder="https://...">
            </div>
          </div>
        </div>

        <!-- Columna derecha -->
        <div class="form-col">
          <div class="form-card">
            <p class="form-card-title"><i class="ti ti-list"></i> Ingredientes</p>
            <div class="field">
              <label>Un ingrediente por línea con cantidad</label>
              <textarea name="ingredientes" rows="7"
                placeholder="200g harina&#10;3 huevos&#10;100ml leche&#10;50g manteca&#10;..."></textarea>
            </div>
          </div>

          <div class="form-card">
            <p class="form-card-title"><i class="ti ti-list-numbers"></i> Pasos de preparación</p>
            <div class="field">
              <label>Describí cada paso</label>
              <textarea name="pasos" rows="7"
                placeholder="Paso 1: Mezclar la harina con los huevos.&#10;Paso 2: Agregar la leche de a poco.&#10;..."></textarea>
            </div>
          </div>
        </div>

      </div>

      <div class="form-actions">
        <a href="/recetas" class="btn-secondary">Cancelar</a>
        <button type="submit" class="btn-primary">
          <i class="ti ti-device-floppy"></i> Guardar receta
        </button>
      </div>
    </form>

  </main>
</div>

<style>
.form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.form-col { display: flex; flex-direction: column; gap: 20px; }
.form-card { background: var(--blanco); border: 1px solid var(--gris-borde); border-radius: 12px; padding: 24px; box-shadow: var(--sombra); }
.form-card-title { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--azul); margin-bottom: 18px; display: flex; align-items: center; gap: 7px; }
.field { margin-bottom: 16px; }
.field:last-child { margin-bottom: 0; }
.field label { display: block; font-size: 0.68rem; font-weight: 500; color: var(--negro); margin-bottom: 6px; letter-spacing: 0.05em; }
.field input[type="text"],
.field input[type="number"],
.field textarea {
  width: 100%; background: var(--gris-fondo); border: 1px solid var(--gris-borde);
  border-radius: 8px; padding: 10px 12px; font-family: var(--font-sans);
  font-size: 0.85rem; color: var(--negro); outline: none;
  transition: border-color var(--tr), box-shadow var(--tr);
  resize: vertical;
}
.field input:focus, .field textarea:focus {
  border-color: var(--azul);
  box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
  background: var(--blanco);
}
.form-actions { display: flex; justify-content: flex-end; gap: 12px; margin-top: 24px; padding-top: 24px; border-top: 1px solid var(--gris-borde); }
.back-link { color: var(--gris-texto); text-decoration: none; font-size: 0.75rem; display: inline-flex; align-items: center; gap: 4px; }
.back-link:hover { color: var(--azul); }
@media (max-width: 900px) { .form-grid { grid-template-columns: 1fr; } }
</style>

</body>
</html>

